{
  "name": "cookboek",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true,
    "useTabs": false,
    "printWidth": 120,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "scripts": {
    "start:frontend": "npm run start -w frontend",
    "start:backend": "npm run dev -w backend",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "test:frontend": "npm run test -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
